generator client {
  provider = "prisma-client"
  output = "../src/db/generated"
  engineType = "client"
  runtime = "bun"
}

datasource db {
  provider = "sqlite"
}

enum ReportKind {
  bug
  feature
  refactor
  other
}

enum JobStatus {
  pending
  claimed
  planning
  plan_ready
  approved
  cancelled
  building
  done
  failed
}

model Repository {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  path      String
  originUrl String?
  channelId String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ReportThread {
  id        Int        @id @default(autoincrement())
  threadId  String     @unique
  kind      ReportKind
  repoSlug  String
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  jobs      Job[]
}

model Job {
  id                Int        @id @default(autoincrement())
  threadId          String
  repoSlug          String
  repoPath          String     @default("")
  worktreePath      String?
  kind              ReportKind
  status            JobStatus  @default(pending)
  context           String?
  workerId          String?
  reporterId        String?
  planMd            String?
  opencodeSessionId String?
  buildSessionId    String?
  issueNumber       Int?
  mergedAt          DateTime?
  prUrl             String?
  branch            String?
  parentJobId       Int?
  autoMode          Boolean    @default(false)
  quickMode         Boolean    @default(false)
  hardwork          Boolean    @default(false)
  parallelPlanCount Int        @default(3)
  hardworkPlans     String?
  hardworkIndividualPlans String?
  selectedPlanIndex Int?
  pendingSuggestion    String?
  planEditToken        String?
  statusMessageId      String?
  pendingQuestions     String?
  pendingQuestionIndex Int?
  pendingAnswers       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  thread            ReportThread @relation(fields: [threadId], references: [threadId])
  parent            Job?         @relation("JobChain", fields: [parentJobId], references: [id])
  followUps         Job[]        @relation("JobChain")
  revisions         PlanRevision[]
}

model PlanRevision {
  id             Int      @id @default(autoincrement())
  jobId          Int
  revisionNumber Int
  planMd         String
  source         String
  createdAt      DateTime @default(now())
  job            Job      @relation(fields: [jobId], references: [id])

  @@unique([jobId, revisionNumber])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
