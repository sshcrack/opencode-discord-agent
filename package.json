{
  "name": "opencode-discord",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:bot": "bun run --cwd packages/bot dev",
    "dev:worker": "bun run --cwd packages/worker dev",
    "build": "bun run build --cwd packages/shared && bun run build --cwd packages/bot && bun run build --cwd packages/worker"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "^1.2.0"
  }
}
