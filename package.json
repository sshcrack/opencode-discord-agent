{
  "name": "discord-agent",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/bot",
    "packages/worker"
  ],
  "scripts": {
    "dev:bot": "bun --cwd packages/bot --env-file=$PWD/.env src/index.ts",
    "dev:worker": "bun --cwd packages/worker --env-file=$PWD/.env src/index.ts",
    "typecheck:bot": "cd packages/bot && bunx tsc --noEmit",
    "typecheck:worker": "cd packages/worker && bunx tsc --noEmit",
    "typecheck": "bun run typecheck:bot && bun run typecheck:worker",
    "db:generate": "cd packages/shared && bunx --bun prisma generate",
    "db:migrate": "cd packages/shared && bunx --bun prisma migrate dev",
    "db:studio": "cd packages/shared && bunx --bun prisma studio"
  },
  "dependencies": {
    "@trpc/server": "^11.17.0",
    "@trpc/client": "^11.17.0",
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@libsql/client": "^0.17.3",
    "discord.js": "^14.26.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prisma": "^7.8.0",
    "dotenv": "^17.4.2"
  }
}
